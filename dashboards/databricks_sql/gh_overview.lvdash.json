{
  "datasets": [
    {
      "name": "repos",
      "displayName": "Trending",
      "queryLines": [
        "SELECT repo_name, contributors, stars, forks FROM gh_analytics_dev.gold.vw_trending_repos ORDER BY contributors DESC LIMIT 20"
      ]
    },
    {
      "name": "dq",
      "displayName": "DQ",
      "queryLines": [
        "SELECT layer, checks, pass_pct FROM gh_analytics_dev.gold.vw_dq_health ORDER BY layer"
      ]
    },
    {
      "name": "lang",
      "displayName": "Lang",
      "queryLines": [
        "SELECT primary_language, events FROM gh_analytics_dev.gold.vw_language_trends ORDER BY events DESC LIMIT 12"
      ]
    },
    {
      "name": "hour",
      "displayName": "Hourly",
      "queryLines": [
        "SELECT event_hour, events FROM gh_analytics_dev.gold.vw_hourly_activity ORDER BY event_hour"
      ]
    }
  ],
  "pages": [
