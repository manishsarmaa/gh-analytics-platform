# Normalize line endings to LF in the repo (checked out as-is on Windows).
# Keeps diffs clean across Windows/Mac/Linux and Databricks.
* text=auto eol=lf

# Explicitly text
*.py     text eol=lf
*.md     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.tf     text eol=lf
*.tfvars text eol=lf
*.toml   text eol=lf
*.txt    text eol=lf
*.cfg    text eol=lf
*.sh     text eol=lf

# Windows-native scripts keep CRLF
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary — never touch
*.pbix   binary
*.png    binary
*.jpg    binary
*.gz     binary
*.parquet binary
