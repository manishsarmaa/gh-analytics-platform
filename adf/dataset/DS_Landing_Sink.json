{
  "name": "DS_Landing_Sink",
  "properties": {
    "description": "Landing target as raw bytes (kept .gz). folder_path e.g. gharchive/year=2024/month=01/day=15/hour=00",
    "linkedServiceName": {
      "referenceName": "ADLS_Landing_LS",
      "type": "LinkedServiceReference"
    },
    "parameters": {
      "folder_path": {
        "type": "string"
      },
      "file_name": {
        "type": "string"
      }
    },
    "annotations": [],
    "type": "Binary",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "landing",
        "folderPath": {
          "value": "@dataset().folder_path",
          "type": "Expression"
        },
        "fileName": {
          "value": "@dataset().file_name",
          "type": "Expression"
        }
      }
    }
  }
}
